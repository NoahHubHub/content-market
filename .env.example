YOUTUBE_API_KEY=your_youtube_api_key_here
SECRET_KEY=change-this-to-a-random-string
APP_URL=https://your-app-url.up.railway.app

# Local development: SQLite (default)
DATABASE_URL=sqlite:///./contentmarket.db

# Production (Railway): Set this in Railway's environment variables panel.
# Railway auto-provisions a PostgreSQL database — copy the DATABASE_URL from
# the "Variables" tab of your PostgreSQL plugin and set it here.
# Example:
# DATABASE_URL=postgresql://user:password@host:5432/railway
